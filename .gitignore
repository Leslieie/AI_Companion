# Jupyter checkpoints
.ipynb_checkpoints/

# Weights & Biases
wandb/

# Project context files (not for git)
CLAUDE.md
ai_companion_repo_bootstrap.md
.claude/

# Eval run logs (keep JSON results, drop raw stdout)
outputs/eval/*.log

# Large dataset files (keep hand-curated annotations)
data/processed/
data/raw/
data/splits/
